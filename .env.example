# Frontend (Vite) environment variables.
# Copy to `.env` (gitignored) and fill in. Only VITE_-prefixed vars are exposed
# to the browser bundle, so never put secrets (service_role key) here.

# Supabase — public anon key, access is gated by RLS
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Google Maps JS API key (maps / location features)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Web Push VAPID public key (browser push notifications)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Sentry DSN — error monitoring. Leave empty to disable (no-op without it).
VITE_SENTRY_DSN=
